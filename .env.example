# ---- Database ----
POSTGRES_USER=influenceiq
POSTGRES_PASSWORD=influenceiq
POSTGRES_DB=influenceiq
DATABASE_URL=postgresql+psycopg://influenceiq:influenceiq@postgres:5432/influenceiq

# ---- Redis (broker + result backend + state cache) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_STATE_DB=redis://redis:6379/2

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- LLM providers ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GENERATE_QUERY_AI_PROVIDER=openrouter
GENERATE_QUERY_AI_MODEL=qwen/qwen3-coder:free
CLASSIFY_BRAND_SAFETY_AI_PROVIDER=
CLASSIFY_BRAND_SAFETY_AI_MODEL=
RESOLVE_IDENTITY_AI_PROVIDER=
RESOLVE_IDENTITY_AI_MODEL=
SCORE_EXPLAIN_AI_PROVIDER=
SCORE_EXPLAIN_AI_MODEL=

# Kimi K2 (Moonshot) - long-context reasoning, query gen, score explanation
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2

# Gemini 2.5 Flash - high-volume cheap path (brand safety, bulk summarization)
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek V4 - entity extraction, identity resolution Pass 3
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4

# OpenAI - GPT-4o-mini (judge) and GPT-5-mini (escalation)
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-5-mini

# ---- Search and crawling ----
BRAVE_SEARCH_API_KEY=
SERP_API_KEY=
OPENSERP_URL=http://openserp:7000
OPENSERP_API_KEY=
SCRAPE_DO_API_KEY=
SCRAPE_DO_BASE_URL=https://api.scrape.do/
SEARCH_RESULT_LIMIT=8
URL_CACHE_TTL_SECONDS=172800
CRAWL_MAX_DEPTH=2
CRAWL_MAX_URLS_PER_CAMPAIGN=100
CRAWL_DEFAULT_MIN_INTERVAL_SECONDS=1
CRAWL_SOCIAL_MIN_INTERVAL_SECONDS=2
CRAWL_MAX_RETRIES=3
CRAWL_BACKOFF_SECONDS=2
CRAWL_BACKOFF_MAX_SECONDS=60
YOUTUBE_API_KEY=

# ---- Embeddings ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Token budgets (per task type, hard caps) ----
TOKEN_BUDGET_QUERY_GEN=2000
TOKEN_BUDGET_BRAND_SAFETY=800
TOKEN_BUDGET_IDENTITY_RESOLUTION=400
TOKEN_BUDGET_SCORE_EXPLAIN=1500

# ---- Scoring ----
SCORE_VERSION=v1.0
CONFIDENCE_CAP_THRESHOLD=3
CONFIDENCE_CAP_VALUE=70

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Optional umgl_ai v2 adapters (all default to off) ----
# Install with `make umgl-install` before enabling any of these.
UMGL_USE_SEMANTIC_V2=0
UMGL_USE_BEHAVIORAL_V2=0
UMGL_USE_GRAPH_V2=0
UMGL_USE_BOT_RINGS_V2=0
UMGL_USE_LLM_EXPLAINER=0
UMGL_LLM_ENDPOINT=
