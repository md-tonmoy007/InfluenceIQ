# ---- Database ----
POSTGRES_USER=influenceiq
POSTGRES_PASSWORD=influenceiq
POSTGRES_DB=influenceiq
DATABASE_URL=postgresql+psycopg://influenceiq:influenceiq@postgres:5432/influenceiq

# ---- Redis (broker + result backend + state cache) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_STATE_DB=redis://redis:6379/2

# ---- Qdrant ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- LLM providers ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ---- LLM routing (per task) ----
# Allowed providers in the current code path: openrouter, gemini
GENERATE_QUERY_AI_PROVIDER=openrouter
GENERATE_QUERY_AI_MODEL=openai/gpt-4o-mini

CLASSIFY_BRAND_SAFETY_AI_PROVIDER=gemini
CLASSIFY_BRAND_SAFETY_AI_MODEL=gemini-2.5-flash

RESOLVE_IDENTITY_AI_PROVIDER=openrouter
RESOLVE_IDENTITY_AI_MODEL=openai/gpt-4o-mini

SCORE_EXPLAIN_AI_PROVIDER=openrouter
SCORE_EXPLAIN_AI_MODEL=openai/gpt-4o-mini

# ---- Search APIs ----
BRAVE_SEARCH_API_KEY=
OPENSERP_URL=http://openserp:7000
OPENSERP_API_KEY=

# ---- Embeddings ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Token budgets (per task type, hard caps) ----
TOKEN_BUDGET_QUERY_GEN=2000
TOKEN_BUDGET_BRAND_SAFETY=800
TOKEN_BUDGET_IDENTITY_RESOLUTION=400
TOKEN_BUDGET_SCORE_EXPLAIN=1500

# ---- Scoring ----
SCORE_VERSION=v1.0
CONFIDENCE_CAP_THRESHOLD=3
CONFIDENCE_CAP_VALUE=70

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
