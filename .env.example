# ============================================================================
# InfluenceIQ — environment variables
# ============================================================================
# This file documents every key the backend actually reads. Keys that exist
# in the wild but are not consumed by the code today are intentionally
# omitted so we don't carry stale configuration forward.
#
# To enable the optional umgl_ai ML backends, install them with
# `make umgl-install` first; the adapter flags at the bottom of this file
# are inert without the install.
# ============================================================================

# ---- Database ----
POSTGRES_USER=influenceiq
POSTGRES_PASSWORD=influenceiq
POSTGRES_DB=influenceiq
DATABASE_URL=postgresql+psycopg://influenceiq:influenceiq@postgres:5432/influenceiq

# ---- Redis (broker + result backend + state cache) ----
# DB 0 is the Celery broker, DB 1 is the Celery result backend,
# DB 2 is the pipeline-state hash / pub-sub channel namespace.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_STATE_DB=redis://redis:6379/2

# ---- Qdrant (vector store; optional ML backend) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- LLM providers (used by the optional ML adapters; ignored if umgl_ai is not installed) ----
# Kimi K2 (Moonshot) — long-context reasoning
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2
# Gemini 2.5 Flash — high-volume cheap path
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# DeepSeek V4 — entity extraction, identity resolution
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4
# OpenAI — judge + escalation
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-5-mini

# ---- Search and crawling ----
BRAVE_SEARCH_API_KEY=
OPENSERP_URL=http://openserp:7000
OPENSERP_API_KEY=
# Apify — Instagram provider fallback (scraping_service uses it)
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=

# ---- Embeddings (optional, used by umgl_ai vector store) ----
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Token budgets (per task type, hard caps) ----
TOKEN_BUDGET_QUERY_GEN=2000
TOKEN_BUDGET_BRAND_SAFETY=800
TOKEN_BUDGET_IDENTITY_RESOLUTION=400
TOKEN_BUDGET_SCORE_EXPLAIN=1500

# ---- Scoring ----
SCORE_VERSION=v1.0
CONFIDENCE_CAP_THRESHOLD=3
CONFIDENCE_CAP_VALUE=70

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Optional umgl_ai v2 adapters (all default to off) ----
# Install with `make umgl-install` before enabling any of these.
UMGL_USE_SEMANTIC_V2=0
UMGL_USE_BEHAVIORAL_V2=0
UMGL_USE_GRAPH_V2=0
UMGL_USE_BOT_RINGS_V2=0
UMGL_USE_LLM_EXPLAINER=0
UMGL_LLM_ENDPOINT=
