# ============================================================================
# InfluenceIQ — environment template (copy to backend/.env)
# ============================================================================
# cp backend/.env.example backend/.env
# See docs/provider-configuration.md for search vs fetch provider guidance.
# See plans/06-env-configuration.md for Plan-06-specific options.
# ============================================================================

# ---- Database ----
POSTGRES_USER=influenceiq
POSTGRES_PASSWORD=influenceiq
POSTGRES_DB=influenceiq
DATABASE_URL=postgresql+psycopg://influenceiq:influenceiq@postgres:5432/influenceiq

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_STATE_DB=redis://redis:6379/2

# ---- Qdrant (optional ML vector store) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# QDRANT_TIMEOUT_SECONDS=10

# ---- LLM providers (optional) ----
# OPENROUTER_API_KEY powers chat-completion + relevance embeddings.
# Falls open to deterministic stubs when absent (no key = no LLM calls).
OPENROUTER_API_KEY=
AI_AGENT_LLM_QUERY_PLANNING=
AI_AGENT_LLM_IDENTITY=0
AI_AGENT_LLM_PROFILE_VERIFY=0
AI_AGENT_LLM_BRAND_SAFETY=0
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-5-mini

# ---- YouTube Data API v3 (Strand A — Plan 06, optional but recommended) ----
# When set, fetch_youtube_profile uses channels.list + videos.list to populate
# authoritative subscriber count, per-video views/likes/comments, the verified
# badge (status.isLinked + customUrl), and the channel's lifetime view count.
# When unset, the provider falls back to the HTML regex path. Free quota:
# 10,000 units/day. Each profile costs 2 units (channels.list=1, videos.list=1)
# so a 50-influencer campaign = 100 units. Get one:
# https://console.cloud.google.com/ → enable YouTube Data API v3 → Create API key.
YOUTUBE_API_KEY=

# ---- Semantic relevance embeddings (Strand C — Plan 06, optional but recommended) ----
# UMGL_EMBEDDING_MODEL is the model id passed to OpenRouter's /embeddings route.
# EMBEDDING_DIM must match the model's output dimension or cosine similarity
# will be wrong. text-embedding-3-small → 1536. Get an OpenRouter key at
# https://openrouter.ai/keys. text-embedding-3-small is ~$0.02/1M tokens.
UMGL_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Search (discovery) ----
# auto: dev→Brave, production→Brave | brave | serpapi | all
SEARCH_PROVIDER_MODE=auto
BRAVE_SEARCH_API_KEY=
SERP_API_KEY=

# ---- Platform fetch (profile scraping) ----
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-profile-scraper
APIFY_TIKTOK_ACTOR=clockworks/tiktok-profile-scraper
APIFY_X_ACTOR=apify/twitter-scraper
SCRAPE_DO_API=

# ---- Platform fetch tuning ----
# Max comments / posts to store per profile.
# PLATFORM_COMMENT_LIMIT=200
# PLATFORM_POST_LIMIT=20
# Target comment count for deep analysis (plan 03).
# DEEP_ANALYSIS_COMMENT_TARGET=2000
# When true, synthetic fixture profiles are accepted as valid fetch results.
# Useful in dev when no API keys are configured.
# ALLOW_SYNTHETIC_FETCH_FALLBACK=false

# ---- YouTube Data API v3 (optional, recommended) ----
# When set, fetch_youtube_profile uses channels.list + videos.list to populate
# authoritative subscriber count, per-video views/likes/comments, the verified
# badge (status.isLinked + customUrl), and the channel's lifetime view count.
# When unset, the provider falls back to the HTML regex path and to the
# "Verified" substring match. Free quota: 10,000 units/day. Each profile costs
# 2 units (channels.list=1, videos.list=1) so a 50-influencer campaign = 100.
# Get one: https://console.cloud.google.com/ → enable YouTube Data API v3 →
# APIs & Services → Credentials → Create Credentials → API key.
YOUTUBE_API_KEY=

# ---- Embeddings (optional) ----
# Used for semantic relevance scoring (plan 06).
# UMGL_EMBEDDING_MODEL is the model ID passed to OpenRouter's /embeddings.
# EMBEDDING_DIM must match the model's output dimension.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
UMGL_EMBEDDING_MODEL=text-embedding-3-small

# ---- Token budgets ----
TOKEN_BUDGET_QUERY_GEN=2000
TOKEN_BUDGET_BRAND_SAFETY=800
TOKEN_BUDGET_IDENTITY_RESOLUTION=400
TOKEN_BUDGET_SCORE_EXPLAIN=1500

# ---- Scoring ----
SCORE_VERSION=v1.0
CONFIDENCE_CAP_THRESHOLD=3
CONFIDENCE_CAP_VALUE=70
# Classifier model for the role-5 fake-risk pipeline. Overrides OPENAI_JUDGE_MODEL
# when set; used by backend/pipeline/model_classifiers.py.
# ROLE5_USE_MODEL_CLASSIFIERS=0
# ROLE5_MODEL_CLASSIFIER_MODEL=
# ROLE5_MODEL_CLASSIFIER_TIMEOUT=8

# ---- Contact info extraction (privacy-sensitive) ----
# ROLE5_EXTRACT_CONTACT_INFO=1
# ROLE5_HASH_CONTACT_IN_EVENTS=1

# ---- Auth / JWT ----
JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Optional ML adapters ----
ML_USE_SEMANTIC_V2=0
ML_USE_BEHAVIORAL_V2=0
ML_USE_GRAPH_V2=0
ML_USE_BOT_RINGS_V2=0
ML_USE_LLM_EXPLAINER=0
ML_LLM_ENDPOINT=https://openrouter.ai/api/v1
UMGL_LLM_BACKEND=openrouter
UMGL_LLM_MODEL=openai/gpt-oss-20b:free
# UMGL_LLM_TIMEOUT_SECS=30

# ---- Stripe (optional) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
FRONTEND_URL=http://localhost:3002
