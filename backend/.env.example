# ============================================================================
# InfluenceIQ — shared Docker env template
# ============================================================================
# Copy to backend/.env and override values for your environment:
#   cp backend/.env.example backend/.env
#
# This file is shared by the backend, workers, and the Dockerized frontend in
# local/prod compose flows, so it includes both backend settings and the
# frontend public-origin variables used by the containers.
# This file documents every key the backend actually reads; keep it in sync
# with backend/.env (same keys, secrets left empty here).
# See docs/provider-configuration.md for search vs fetch provider guidance.
# See plans/06-env-configuration.md for Plan-06-specific options.
#
# To enable the optional umgl_ai ML backends, install them with
# make umgl-install first; the adapter flags at the bottom of this file
# are inert without the install.
# ============================================================================

# ---- App ----
# Allowed values: dev | staging | prod
APP_ENV=dev
LOG_LEVEL=INFO

# ---- Database ----
POSTGRES_USER=influenceiq
POSTGRES_PASSWORD=change-me
POSTGRES_DB=influenceiq
DATABASE_URL=postgresql+psycopg://influenceiq:change-me@postgres:5432/influenceiq

# ---- Redis (broker + result backend + state cache) ----
# DB 0 is the Celery broker, DB 1 is the Celery result backend,
# DB 2 is the pipeline-state hash / pub-sub channel namespace.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_STATE_DB=redis://redis:6379/2

# ---- Qdrant (vector store; optional ML backend) ----
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# QDRANT_TIMEOUT_SECONDS=10

# ---- Auth / JWT ----
# Must be overridden in prod; startup fails if this stays at the default.
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- LLM providers ----
# OPENROUTER_API_KEY powers chat-completion + relevance embeddings.
# Falls open to deterministic stubs when absent (no key = no LLM calls).
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2
# Gemini 2.5 Flash — high-volume cheap path
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# DeepSeek V4 — entity extraction, identity resolution
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4
# OpenAI — judge + escalation
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-4o-mini
OPENAI_ESCALATION_MODEL=gpt-5-mini

# ---- AI-agent feature flags ----
# QUERY_PLANNING also accepts a model id instead of a boolean.
AI_AGENT_LLM_QUERY_PLANNING=
AI_AGENT_LLM_IDENTITY=0
AI_AGENT_LLM_PROFILE_VERIFY=0
AI_AGENT_LLM_BRAND_SAFETY=0

# ---- Semantic relevance embeddings (Strand C — Plan 06, optional but recommended) ----
# UMGL_EMBEDDING_MODEL is the model id passed to OpenRouter's /embeddings route.
# EMBEDDING_DIM must match the model's output dimension or cosine similarity
# will be wrong. text-embedding-3-small → 1536. Get an OpenRouter key at
# https://openrouter.ai/keys. text-embedding-3-small is ~$0.02/1M tokens.
# EMBEDDING_MODEL is kept for backward compat; new code should prefer
# UMGL_EMBEDDING_MODEL.
UMGL_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Search (discovery) ----
# auto: dev→Brave, production→Brave | brave | serpapi | all
SEARCH_PROVIDER_MODE=auto
BRAVE_SEARCH_API_KEY=
SERP_API_KEY=

# ---- Platform fetch (profile scraping) ----
# Apify — Instagram provider fallback (scraping_service uses it)
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-profile-scraper
APIFY_TIKTOK_ACTOR=clockworks/tiktok-profile-scraper
APIFY_X_ACTOR=apify/twitter-scraper
SCRAPE_DO_API=
YOUTUBE_API_KEY=

# ---- Platform fetch tuning ----
# Max comments / posts to store per profile.
# PLATFORM_COMMENT_LIMIT=200
# PLATFORM_POST_LIMIT=20
# Target comment count for deep analysis (plan 03).
# DEEP_ANALYSIS_COMMENT_TARGET=2000
# When true, synthetic fixture profiles are accepted as valid fetch results.
# Useful in dev when no API keys are configured.
# ALLOW_SYNTHETIC_FETCH_FALLBACK=false

# ---- Comment analyzer ----
APIFY_INSTAGRAM_COMMENTS_ACTOR=apify/instagram-comment-scraper
APIFY_TIKTOK_COMMENTS_ACTOR=clockworks/tiktok-comments-scraper
# kill-switch for the cheap path
COMMENT_FETCH_ON_ENRICH=True
# posts per platform on enrich
ENRICH_COMMENT_POST_LIMIT=3
ENRICH_COMMENTS_PER_POST=50
# one commentThreads page
YOUTUBE_COMMENTS_PER_POST=100
# 6 hours, matches the YOUTUBE_API_CACHE_TTL constant in
# backend/pipeline/content/cache.py
COMMENT_CACHE_TTL_SECONDS=21600

# ---- Token budgets (per task type, hard caps) ----
TOKEN_BUDGET_QUERY_GEN=2000
TOKEN_BUDGET_BRAND_SAFETY=800
TOKEN_BUDGET_IDENTITY_RESOLUTION=400
TOKEN_BUDGET_SCORE_EXPLAIN=1500

# ---- Scoring ----
SCORE_VERSION=v1.0
CONFIDENCE_CAP_THRESHOLD=3
CONFIDENCE_CAP_VALUE=70

# Optional: route brand-safety/fake-signal classification through an
# OpenAI-backed model in addition to the deterministic block-list scan
# (backend/pipeline/model_classifiers.py, called once per score from
# scan_brand_safety). Off by default; requires OPENAI_API_KEY when
# enabled. ROLE5_MODEL_CLASSIFIER_MODEL overrides the model (falls back
# to OPENAI_JUDGE_MODEL, then gpt-4o-mini); ROLE5_MODEL_CLASSIFIER_TIMEOUT
# overrides the request timeout in seconds (default 8).
ROLE5_USE_MODEL_CLASSIFIERS=0
# ROLE5_MODEL_CLASSIFIER_MODEL=
# ROLE5_MODEL_CLASSIFIER_TIMEOUT=8

# ---- Contact info extraction ----
ROLE5_EXTRACT_CONTACT_INFO=1
ROLE5_HASH_CONTACT_IN_EVENTS=1

# ---- Optional backend.ml v2 adapters (all default to off) ----
# Enable these only after installing any ML-specific dependencies you need.
# Deep-tuning UMGL_* model/checkpoint overrides live in
# backend/pipeline/fusion/backends/ and all have sane code defaults.
ML_USE_SEMANTIC_V2=0
ML_USE_BEHAVIORAL_V2=0
ML_USE_GRAPH_V2=0
ML_USE_BOT_RINGS_V2=0
ML_USE_LLM_EXPLAINER=0
ML_LLM_ENDPOINT=https://openrouter.ai/api/v1
# LLM backend selection (registry slot "llm"). openrouter -> OpenAI-compatible
# chat-completions via OPENROUTER_API_KEY. Query planning also reads the model
# from AI_AGENT_LLM_QUERY_PLANNING; UMGL_LLM_MODEL is the adapter default.
UMGL_LLM_BACKEND=openrouter
UMGL_LLM_MODEL=openai/gpt-oss-20b:free
# UMGL_LLM_TIMEOUT_SECS=30

# ---- Optional ML stores (used by the `ml` compose profile only) ----
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=umgl
# MINIO_SECRET_KEY=change-me
# MINIO_SECURE=false
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DATABASE=umgl

# ---- Stripe (optional — billing endpoints return 503 when unset) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=

# ---- Frontend / public origins ----
# Local Docker frontend runs on http://localhost:3002.
# In prod set these to your public domain, e.g.
#   FRONTEND_URL=https://cuet.shafayetsadi.dev
#   NEXT_PUBLIC_API_BASE_URL=https://cuet.shafayetsadi.dev
#   NEXT_PUBLIC_WS_BASE_URL=wss://cuet.shafayetsadi.dev
FRONTEND_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:8002
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8002
